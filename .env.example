# ==================== BOT ====================
BOT_TOKEN=your_bot_token_here

# Super admin Telegram ID lari (vergul bilan ajratiladi)
SUPER_ADMIN_IDS=123456789,987654321

# ==================== KINO KANALI ====================
# Kinolar saqlanadigan Telegram kanal ID si (masalan: -1001234567890)
MOVIE_CHANNEL_ID=-1001234567890

# ==================== DATABASE ====================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kinobot
DB_USER=kinobot_user
DB_PASS=strong_password_here

# Full URL (avtomatik quriladi, lekin manual ham bersa bo'ladi)
# DATABASE_URL=postgresql+asyncpg://kinobot_user:strong_password_here@localhost:5432/kinobot

# ==================== REDIS ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_URL=redis://localhost:6379/0

# ==================== BOT SOZLAMALARI ====================
# Default til: uz | ru | en
DEFAULT_LANGUAGE=uz

# Throttling: bir daqiqada maksimal so'rovlar soni
THROTTLE_RATE=10

# Bot webhook yoki polling rejimi: polling | webhook
BOT_MODE=polling

# Webhook uchun (faqat BOT_MODE=webhook bo'lsa)
WEBHOOK_HOST=https://yourdomain.com
WEBHOOK_PATH=/webhook
WEBHOOK_PORT=8080
