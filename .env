# ==================== BOT SOZLAMALARI ====================
# Default til: uz | ru | en
DEFAULT_LANGUAGE=uz

# Throttling: bir daqiqada maksimal so'rovlar soni
THROTTLE_RATE=10

# Bot webhook yoki polling rejimi: polling | webhook
BOT_MODE=polling

# Webhook uchun (faqat BOT_MODE=webhook bo'lsa)
WEBHOOK_HOST=https://yourdomain.com
WEBHOOK_PATH=/webhook
WEBHOOK_PORT=8080

# ==================== ADMIN WEB PANEL ====================
