# ====================================
# KinoBot — Русский язык (ru)
# ====================================

# ── Общее ───────────────────────────
btn-cancel = ❌ Отмена
btn-back = ◀️ Назад
btn-yes = ✅ Да
btn-no = ❌ Нет
btn-close = 🔒 Закрыть
btn-refresh = 🔄 Обновить

# ── Старт / Приветствие ──────────────
welcome =
    👋 Привет, <b>{ $name }</b>!

    🎬 Добро пожаловать в <b>KinoBot</b>!

    С помощью этого бота вы можете:
    🎥 Получить фильм по коду
    🔍 Найти фильм по названию

    📌 <b>Как пользоваться:</b>
    • Отправьте код фильма (например: <code>1234</code>) — фильм придёт мгновенно
    • Или нажмите <b>🔍 Поиск</b> для поиска по названию

    ❓ Нужна помощь? Напишите /help

# ── Помощь ──────────────────────────
help =
    ℹ️ <b>KinoBot — Руководство</b>

    🔢 <b>Отправьте код фильма:</b>
    Отправьте код из канала (например <code>1234</code>) — фильм придёт мгновенно.

    🔍 <b>Поиск по названию:</b>
    Нажмите 🔍 Поиск или /search, затем введите название фильма.

    📌 <b>Команды:</b>
    /start — Перезапустить бота
    /search — Поиск фильма
    /help — Эта справка

# ── Неизвестное сообщение ───────────
unknown-command =
    ❓ Такой команды не существует.

    📌 Доступные команды:
    /start — Запустить бота
    /search — Поиск фильма
    /help — Помощь

unknown-message = 💡 Отправьте код фильма (например: <code>1234</code>) или нажмите <b>🔍 Поиск</b>.

# ── Подписка ────────────────────────
subscription-required =
    🔒 <b>Для использования бота подпишитесь на каналы:</b>

subscribe-btn = 📢 { $title }
check-subscription-btn = ✅ Я подписался, проверить!

subscription-ok = ✅ Спасибо! Теперь вы можете пользоваться ботом.
subscription-fail =
    ❌ Вы ещё не подписались на все каналы.

    Подпишитесь и проверьте снова:

# ── Поиск фильма ────────────────────
search-prompt =
    🔍 <b>Поиск</b>

    Введите название фильма (например: <code>Inception</code>)
    или код фильма (например: <code>1234</code>):
search-no-results = 😔 По запросу <b>"{ $query }"</b> ничего не найдено.
search-results-header = 🎬 <b>Результаты по "{ $query }":</b>
search-result-item = { $num }. <b>{ $title }</b> ({ $year }) — код: <code>{ $code }</code>
search-select-prompt = ⬇️ Отправьте код фильма или выберите из списка:

movie-not-found = ❌ Фильм с кодом <b>{ $code }</b> не найден.

# ── Информация о фильме ─────────────
movie-info =
    🎬 <b>{ $title }</b>
    { $year ->
        [0] 
        *[other] 📅 Год: <b>{ $year }</b>
    }
    { $duration ->
        [0] 
        *[other] ⏱ Длительность: <b>{ $duration } мин</b>
    }
    { $country ->
        [""] 
        *[other] 🌍 Страна: <b>{ $country }</b>
    }
    { $genres ->
        [""] 
        *[other] 🎭 Жанр: <b>{ $genres }</b>
    }
    { $lang_type ->
        [""] 
        *[other] 🔊 Язык: <b>{ $lang_type }</b>
    }
    { $imdb ->
        [0] 
        *[other] ⭐ IMDb: <b>{ $imdb }</b>
    }
    { $kinopoisk ->
        [0] 
        *[other] 🎯 Кинопоиск: <b>{ $kinopoisk }</b>
    }
    { $description ->
        [""] 
        *[other] 
            📝 <i>{ $description }</i>
    }

    👁 Просмотров: <b>{ $views }</b>

# ── Ошибки ──────────────────────────
error-general = ❌ Произошла ошибка. Попробуйте ещё раз.
error-banned =
    🚫 Вы заблокированы.
    { $reason ->
        [""] 
        *[other] Причина: <i>{ $reason }</i>
    }
user-not-found = ❌ Пользователь не найден.

# ── Админ панель ────────────────────
admin-panel =
    🎛 <b>Панель администратора</b>

    👤 Админ: <b>{ $name }</b>
    🏷 Роль: <b>{ $role }</b>

btn-admin-movies = 🎬 Фильмы
btn-admin-channels = 📢 Каналы
btn-admin-admins = 👮 Администраторы
btn-admin-broadcast = 📣 Рассылка
btn-admin-stats = 📊 Статистика
btn-admin-sync = 🔄 Синхронизация

access-denied = 🚫 У вас нет прав для выполнения этого действия.

# ── Forward handler ─────────────────
movie-added = ✅ Новый фильм добавлен
movie-updated = 🔄 Фильм обновлён
forward-no-caption = ❌ Caption не найден. Информация о фильме должна быть в caption.
forward-no-code = ❌ Код фильма не найден. Проверьте формат caption (#KOD_1234).

# ── Синхронизация ───────────────────
sync-started =
    🔄 <b>Синхронизация началась.</b>

    Проверяются сообщения из канала фильмов...
    Это может занять несколько минут.

    ⚠️ Сообщения будут кратко появляться в чате администратора и автоматически удаляться.

sync-done =
    ✅ <b>Синхронизация завершена!</b>

    ➕ Добавлено: <b>{ $added }</b>
    🔄 Обновлено: <b>{ $updated }</b>
    ⏭ Пропущено: <b>{ $skipped }</b>
    ⏱ Время: <b>{ $duration } сек</b>

sync-failed = ❌ Синхронизация завершилась с ошибкой: <code>{ $error }</code>
sync-already-running = ⏳ Синхронизация уже запущена, подождите...

# ── Каналы ──────────────────────────
channels-list = 📢 <b>Список обязательных каналов:</b>
channel-add-prompt = Отправьте username или ID канала (например: @mychannel или -1001234567890):
channel-added = ✅ Канал <b>{ $title }</b> добавлен.
channel-removed = ✅ Канал удалён.
channel-not-found = ❌ Канал не найден.
channel-already-exists = ⚠️ Этот канал уже в списке.
channel-bot-not-admin = ❌ Бот не является администратором этого канала. Сначала добавьте бота как администратора.

btn-channel-remove = 🗑 Удалить
btn-channel-add = ➕ Добавить канал

# ── Администраторы ──────────────────
admins-list = 👮 <b>Список администраторов:</b>
admin-add-prompt = Отправьте Telegram ID пользователя, которого хотите сделать администратором:
admin-added = ✅ <b>{ $name }</b> назначен администратором.
admin-removed = ✅ Права администратора сняты.
admin-not-found = ❌ Администратор не найден.
admin-already-exists = ⚠️ Этот пользователь уже является администратором.
admin-cannot-remove-super = 🚫 Нельзя удалить супер-администратора.

# ── Рассылка ────────────────────────
broadcast-choose-target = 📣 <b>Выберите аудиторию для рассылки:</b>
btn-target-all = 👥 Все пользователи
btn-target-active-7d = ✅ Активные (7 дней)
btn-target-active-30d = ✅ Активные (30 дней)
btn-target-lang-uz = 🇺🇿 Узбеки
btn-target-lang-ru = 🇷🇺 Русские
btn-target-lang-en = 🇺🇸 Англичане

broadcast-send-message = ✉️ Отправьте сообщение для рассылки (текст, фото, видео):
broadcast-preview =
    👁 <b>Предпросмотр:</b>

    📊 Цель: <b>{ $target }</b>
    👥 Получателей: <b>{ $count }</b>

    Продолжить рассылку?

broadcast-started = 📣 Рассылка начата. Будет отправлено <b>{ $total }</b> сообщений...
broadcast-progress = ⏳ <b>{ $sent }/{ $total }</b> отправлено...
broadcast-done =
    ✅ <b>Рассылка завершена!</b>

    📤 Отправлено: <b>{ $sent }</b>
    ❌ Ошибок: <b>{ $failed }</b>
    ⏱ Время: <b>{ $duration } сек</b>

# ── Статистика ──────────────────────
stats =
    📊 <b>Статистика бота</b>

    👤 <b>Пользователи:</b>
    ├ Всего: <b>{ $total_users }</b>
    ├ Сегодня новых: <b>{ $today_users }</b>
    ├ За неделю новых: <b>{ $week_users }</b>
    ├ За месяц новых: <b>{ $month_users }</b>
    ├ Активных (7 дн): <b>{ $active_7d }</b>
    ├ Активных (30 дн): <b>{ $active_30d }</b>
    └ Заблокированных: <b>{ $banned }</b>

    🎬 <b>Фильмы:</b>
    ├ Всего: <b>{ $total_movies }</b>
    └ Всего просмотров: <b>{ $total_views }</b>

    🌐 <b>По языкам:</b>
    ├ 🇺🇿 Узбекский: <b>{ $lang_uz }</b>
    ├ 🇷🇺 Русский: <b>{ $lang_ru }</b>
    └ 🇺🇸 Английский: <b>{ $lang_en }</b>

# ── Модерация ───────────────────────
ban-prompt = Отправьте ID и причину блокировки:

    Формат: <code>ID | Причина</code>
    Пример: <code>123456789 | Спам</code>

ban-success =
    🚫 <b>{ $name }</b> заблокирован.
    Причина: <i>{ $reason }</i>

unban-prompt = Отправьте ID пользователя для разблокировки:
unban-success = ✅ <b>{ $name }</b> разблокирован.
unban-not-banned = ⚠️ Этот пользователь не заблокирован.

user-info =
    👤 <b>Информация о пользователе:</b>

    🆔 ID: <code>{ $telegram_id }</code>
    👤 Имя: <b>{ $name }</b>
    📛 Username: { $username }
    🌐 Язык: <b>{ $language }</b>
    📅 Дата регистрации: <b>{ $registered }</b>
    🕐 Последняя активность: <b>{ $last_active }</b>
    🚫 Бан: <b>{ $is_banned }</b>
    { $ban_reason ->
        [""] 
        *[other] 📝 Причина бана: <i>{ $ban_reason }</i>
    }
